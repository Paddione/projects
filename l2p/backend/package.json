{
  "name": "learn2play-backend",
  "version": "1.0.0",
  "description": "Learn2Play multiplayer quiz game backend",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:nonblocking": "tsc || true",
    "build:with-tsc-log": "(tsc || true) && node ./scripts/tsc-log.mjs",
    "db:check-plans": "tsx --import tsx src/cli/database.ts check-plans",
    "db:explain": "tsx --import tsx src/cli/database.ts explain",
    "db:explain:file": "tsx --import tsx src/cli/database.ts explain-file",
    "db:health": "tsx --import tsx src/cli/database.ts health",
    "db:migrate": "tsx --import tsx src/cli/database.ts migrate",
    "db:status": "tsx --import tsx src/cli/database.ts status",
    "db:test": "tsx --import tsx src/cli/database.ts test",
    "db:top-slow": "tsx --import tsx src/cli/database.ts top-slow",
    "db:validate": "tsx --import tsx src/cli/database.ts validate",
    "dev": "tsx watch src/server.ts",
    "dev:nonblocking": "tsx src/server.ts",
    "dev:tsx": "tsx watch src/server.ts",
    "prebuild": "npm --prefix ../packages/error-handling install --legacy-peer-deps && npm --prefix ../packages/error-handling run build",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:with-db": "npm run --prefix .. test:setup:db && npm run test",
    "test:ai": "tsx --import tsx src/cli/test-ai.ts",
    "test:ai-mock": "tsx --import tsx src/cli/test-ai-mock.ts",
    "test:ai-real": "tsx --import tsx src/cli/test-ai-real.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "TEST_TYPE=e2e vitest run src/__tests__/e2e --passWithNoTests",
    "test:email": "../scripts/test-email.sh",
    "test:unit": "vitest run",
    "test:unit:ci": "TEST_ENVIRONMENT=ci vitest run",
    "test:unit:local": "vitest run",
    "test:watch": "vitest",
    "tsc:log": "node ./scripts/tsc-log.mjs",
    "typecheck": "tsc -p tsconfig.strict.json --noEmit",
    "typecheck:loose": "tsc -p tsconfig.json --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "check:deprecated": "node -e \"const fs=require('fs'); const path='package-lock.json'; if(!fs.existsSync(path)){console.log('No package-lock.json found.'); process.exit(0);} const lock=JSON.parse(fs.readFileSync(path,'utf8')); const deprecated=Object.entries(lock.packages||{}).filter(([,info])=>info.deprecated); if(!deprecated.length){console.log('No deprecated packages.'); process.exit(0);} deprecated.forEach(([name,info])=>{const pkg=name.replace(/^node_modules\\//,''); console.log(pkg + ': ' + info.deprecated);}); process.exit(1);\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.12",
    "bcryptjs": "^3.0.3",
    "chromadb": "^3.0.10",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "error-handling": "file:../packages/error-handling",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.1.5",
    "joi": "^17.9.1",
    "jsdom": "^27.4.0",
    "jsonwebtoken": "^9.0.0",
    "langchain": "^1.2.7",
    "mammoth": "^1.6.0",
    "marked": "^9.1.6",
    "multer": "^2.0.0",
    "nodemailer": "^6.9.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.10.0",
    "prom-client": "^15.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.6.1",
    "test-config": "file:../packages/test-config"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.14.14",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.6.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^4.1.0",
    "artillery": "2.0.27",
    "eslint": "^9.32.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^3.12.6",
    "typescript": "^5.0.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "babel-plugin-istanbul": {
      "test-exclude": "7.0.1"
    },
    "module-lookup-amd": {
      "glob": "10.5.0"
    }
  }
}
