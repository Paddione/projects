# ═══════════════════════════════════════════════════════════════════
# Homeoffice MVP — Konfiguration
# Datei kopieren: cp .env.example .env
# Dann alle Werte ausfüllen — .env niemals committen!
# ═══════════════════════════════════════════════════════════════════

# ── DuckDNS Domains ──────────────────────────────────────────────────
# Jeder Dienst bekommt eine eigene DuckDNS-Subdomain.
# Alle 5 müssen einmalig auf https://www.duckdns.org angelegt werden.
# Empfohlenes Schema: <projektname>-<dienst>
#
# Beispiel für Projekt "bachelorprojekt":
MM_DOMAIN=bachelorprojekt-chat.duckdns.org
KC_DOMAIN=bachelorprojekt-auth.duckdns.org
NC_DOMAIN=bachelorprojekt-files.duckdns.org
JITSI_DOMAIN=bachelorprojekt-meet.duckdns.org
LLDAP_DOMAIN=bachelorprojekt-ldap.duckdns.org

# ── DuckDNS Updater ──────────────────────────────────────────────────
# Token von der duckdns.org Startseite kopieren.
# SUBDOMAINS: nur die Subdomains OHNE .duckdns.org, kommagetrennt.
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DUCKDNS_SUBDOMAINS=bachelorprojekt-chat,bachelorprojekt-auth,bachelorprojekt-files,bachelorprojekt-meet,bachelorprojekt-ldap

# ── Jitsi JVB ────────────────────────────────────────────────────────
# Öffentliche IP/Domain des Hosts für Jitsi Video-Mediendaten.
# DuckDNS-Domain eintragen — wird automatisch aktuell gehalten.
# Eine der 5 oben angelegten Domains, z.B. die Meet-Domain:
JVB_ADVERTISE_IPS=bachelorprojekt-meet.duckdns.org
# Internes XMPP-Suffix (nur der Domainname ohne Schema, z.B. bachelorprojekt-meet.duckdns.org)
JITSI_XMPP_SUFFIX=bachelorprojekt-meet.duckdns.org

# ── SSL / Let's Encrypt ──────────────────────────────────────────────
ACME_EMAIL=your@email.de

# ── Speichermedium ───────────────────────────────────────────────────
# Externer Speicherpfad (NAS, USB). Leer lassen → ./data
# Beispiele: /mnt/nas/homeoffice  /mnt/usb/homeoffice
STORAGE_PATH=./data

# ── Keycloak ─────────────────────────────────────────────────────────
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN

# ── Mattermost ───────────────────────────────────────────────────────
MATTERMOST_DB_PASSWORD=CHANGE_ME_MATTERMOST_DB
# OIDC Secrets: VOR dem Deployment setzen (openssl rand -base64 32)
# Werden beim ersten Keycloak-Start automatisch in den Realm importiert.
# Kein manuelles Einrichten in der Admin-Console nötig.
MATTERMOST_OIDC_SECRET=CHANGE_ME_MATTERMOST_OIDC
NEXTCLOUD_OIDC_SECRET=CHANGE_ME_NEXTCLOUD_OIDC

# ── Nextcloud ────────────────────────────────────────────────────────
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DB
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_NEXTCLOUD_ADMIN

# ── LLDAP ────────────────────────────────────────────────────────────
# Starke Zufallswerte: openssl rand -base64 32
LLDAP_JWT_SECRET=CHANGE_ME_LLDAP_JWT
LLDAP_LDAP_USER_PASS=CHANGE_ME_LLDAP_ADMIN_PASS
LLDAP_DB_PASSWORD=CHANGE_ME_LLDAP_DB
# Base DN aus deinem Projektnamen ableiten:
#   bachelorprojekt-chat.duckdns.org → LLDAP_BASE_DOMAIN=bachelorprojekt-chat, LLDAP_BASE_TLD=duckdns
LLDAP_BASE_DOMAIN=bachelorprojekt-ldap
LLDAP_BASE_TLD=duckdns

# ── Backup ───────────────────────────────────────────────────────────
# Beide Targets sind optional. Leer lassen = kein Backup zu diesem Ziel.
# Backup läuft täglich um 02:00 UTC (Mattermost, Nextcloud, SSL-Certs).

# Filen.io — https://app.filen.io (kostenlos bis 10GB)
FILEN_EMAIL=
FILEN_PASSWORD=
FILEN_REMOTE_PATH=homeoffice-mvp

# SMB / NAS
SMB_HOST=
SMB_SHARE=
SMB_USER=
SMB_PASS=
SMB_PORT=445
SMB_DOMAIN=WORKGROUP
SMB_REMOTE_PATH=homeoffice-mvp

# ── Jitsi ────────────────────────────────────────────────────────────
# Starke Zufallspasswörter: openssl rand -base64 32
JICOFO_AUTH_PASSWORD=CHANGE_ME_JICOFO
JVB_AUTH_PASSWORD=CHANGE_ME_JVB
