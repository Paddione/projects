# ═══════════════════════════════════════════════════════════════════
# Homeoffice MVP — Konfiguration
# Datei kopieren: cp .env.example .env
# Dann alle Werte ausfüllen und .env niemals committen!
# ═══════════════════════════════════════════════════════════════════

# ── Domain ──────────────────────────────────────────────────────────
# Eigene Domain (z.B. korczewski.de) ODER DuckDNS-Domain
# Bei DuckDNS: DOMAIN=myhome.duckdns.org
DOMAIN=yourname.duckdns.org

# ── DuckDNS ─────────────────────────────────────────────────────────
# Account erstellen: https://www.duckdns.org/
# 1. Subdomain anlegen (z.B. "myhome" → myhome.duckdns.org)
# 2. Token von der Startseite kopieren
# Tipp: Mehrere Subdomains: DUCKDNS_SUBDOMAINS=sub1,sub2
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DUCKDNS_SUBDOMAINS=yourname

# ── Jitsi JVB Advertise IP ──────────────────────────────────────────
# Die öffentlich erreichbare IP/Domain des Hosts für Jitsi-Mediendaten.
# Bei DuckDNS einfach die DuckDNS-Domain eintragen — wird automatisch aktuell gehalten.
JVB_ADVERTISE_IPS=yourname.duckdns.org

# ── SSL / Let's Encrypt ──────────────────────────────────────────────
ACME_EMAIL=your@email.de

# ── Speichermedium ──────────────────────────────────────────────────
# Optionaler externer Speicherpfad für persistente Daten (NAS, USB, etc.)
# Alle Dienste (Mattermost-Uploads, Nextcloud-Daten, Backups) nutzen diesen Pfad.
# Leer lassen oder ./data → lokales Verzeichnis neben docker-compose.yml
# Beispiele:
#   STORAGE_PATH=/mnt/nas/homeoffice
#   STORAGE_PATH=/mnt/usb/homeoffice
#   STORAGE_PATH=/data/homeoffice
STORAGE_PATH=./data

# ── Keycloak ────────────────────────────────────────────────────────
KEYCLOAK_DB_PASSWORD=CHANGE_ME_KEYCLOAK_DB
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN

# ── Mattermost ──────────────────────────────────────────────────────
MATTERMOST_DB_PASSWORD=CHANGE_ME_MATTERMOST_DB
# OIDC Secret aus Keycloak Client-Konfiguration kopieren
MATTERMOST_OIDC_SECRET=CHANGE_ME_OIDC_SECRET

# ── Nextcloud ───────────────────────────────────────────────────────
NEXTCLOUD_DB_PASSWORD=CHANGE_ME_NEXTCLOUD_DB
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_NEXTCLOUD_ADMIN

# ── LLDAP ───────────────────────────────────────────────────────────
# Starke Zufallswerte generieren: openssl rand -base64 32
LLDAP_JWT_SECRET=CHANGE_ME_LLDAP_JWT
LLDAP_LDAP_USER_PASS=CHANGE_ME_LLDAP_ADMIN_PASS
LLDAP_DB_PASSWORD=CHANGE_ME_LLDAP_DB
# Base DN aus deiner Domain ableiten:
#   korczewski.de  → LLDAP_BASE_DOMAIN=korczewski, LLDAP_BASE_TLD=de
#   example.com    → LLDAP_BASE_DOMAIN=example,    LLDAP_BASE_TLD=com
LLDAP_BASE_DOMAIN=yourname
LLDAP_BASE_TLD=duckdns

# ── Jitsi ───────────────────────────────────────────────────────────
# Starke Zufallspasswörter generieren: openssl rand -base64 32
JICOFO_AUTH_PASSWORD=CHANGE_ME_JICOFO
JVB_AUTH_PASSWORD=CHANGE_ME_JVB
