# =============================================================================
# Shop Service — LOCAL DEVELOPMENT Reference
# =============================================================================
# For k3s deployment, all secrets are defined in the ROOT .env:
#   /home/patrick/projects/.env  (SHOP_* prefixed variables)
#
# generate-secrets.sh maps ROOT variables to these NON-PREFIXED names:
#   SHOP_DATABASE_URL      →  DATABASE_URL
#   SHOP_NEXTAUTH_SECRET   →  NEXTAUTH_SECRET
#   SHOP_AUTH_SECRET        →  AUTH_SECRET
#   SHOP_AUTH_GOOGLE_ID     →  AUTH_GOOGLE_ID
#   SHOP_AUTH_GOOGLE_SECRET →  AUTH_GOOGLE_SECRET
#   STRIPE_* variables pass through unchanged
#
# To bootstrap from scratch:
#   cd /home/patrick/projects
#   ./scripts/generate-env.sh
#   ./k8s/scripts/utils/generate-secrets.sh
# =============================================================================

# Database (local dev: localhost:5432, k8s: shared-postgres:5432)
DATABASE_URL="postgresql://shop_user:shop_password@localhost:5432/shop_db?schema=public"

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3004

# Google OAuth (NextAuth provider)
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Stripe (use test keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Auth
AUTH_SECRET=your_auth_secret_here
AUTH_TRUST_HOST=true
AUTH_SERVICE_URL=http://localhost:5500
