{
    "name": "arena-backend",
    "version": "1.0.0",
    "description": "Arena Backend - Express + Socket.io game server",
    "type": "module",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "db:migrate": "tsx src/cli/database.ts migrate"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "drizzle-orm": "^0.39.3",
        "express": "^4.21.2",
        "helmet": "^8.0.0",
        "pg": "^8.13.1",
        "socket.io": "^4.8.1",
        "uuid": "^11.0.5"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/node": "^22.13.5",
        "@types/pg": "^8.11.11",
        "@types/uuid": "^10.0.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7.3"
    }
}