{
    "name": "arena-frontend",
    "version": "1.0.0",
    "description": "Arena Frontend - PixiJS + React game client",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "prebuild": "npm --prefix ../../shared-infrastructure/shared/3d run build",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@pixi/utils": "^7.4.2",
        "@types/three": "^0.170.0",
        "howler": "^2.2.4",
        "pixi.js": "^7.4.2",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.1.3",
        "shared-3d": "file:../../shared-infrastructure/shared/3d",
        "socket.io-client": "^4.8.1",
        "three": "^0.170.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/howler": "^2.2.12",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.4",
        "happy-dom": "^20.8.3",
        "jsdom": "^28.1.0",
        "typescript": "^5.7.3",
        "vite": "^6.1.0",
        "vitest": "^4.0.18"
    }
}
