# =============================================================================
# Auth Service — LOCAL DEVELOPMENT Reference
# =============================================================================
# For k3s deployment, all secrets are defined in the ROOT .env:
#   /home/patrick/projects/.env  (AUTH_* prefixed variables)
#
# generate-secrets.sh maps ROOT variables to these NON-PREFIXED names:
#   AUTH_DATABASE_URL  →  DATABASE_URL
#   AUTH_JWT_SECRET    →  JWT_SECRET
#   AUTH_SESSION_SECRET → SESSION_SECRET
#   (etc.)
#
# To bootstrap from scratch:
#   cd /home/patrick/projects
#   ./scripts/generate-env.sh
#   ./k8s/scripts/utils/generate-secrets.sh
# =============================================================================

# Server Configuration
PORT=5500
NODE_ENV=development

# Database (local dev: localhost:5432, k8s: shared-postgres:5432)
DATABASE_URL=postgresql://auth_user:auth_password@localhost:5432/auth_db

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Session
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_MAX_AGE=2592000000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5500/api/oauth/google/callback

# OAuth 2.0 (auth service as provider for L2P, Shop, etc.)
OAUTH_CODE_EXPIRY=600
OAUTH_ALLOWED_REDIRECT_URIS=https://l2p.korczewski.de/auth/callback,http://localhost:3000/auth/callback

# Allowed Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3004,http://localhost:5000,http://localhost:5100,http://localhost:5500,https://l2p.korczewski.de
APP_URL=http://localhost:5500

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-without-spaces
SMTP_FROM=your-email@gmail.com

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900000
