# =============================================================================
# CENTRALIZED ENVIRONMENT CONFIGURATION
# =============================================================================
# This is the SINGLE SOURCE OF TRUTH for all service configuration.
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Auto-generate secrets:  ./scripts/generate-env.sh
#      OR manually fill in values below.
#   3. Generate K8s secrets:  ./k8s/scripts/utils/generate-secrets.sh
#
# NAMING CONVENTION:
#   Root .env uses PREFIXED names (AUTH_JWT_SECRET, L2P_DATABASE_URL, etc.)
#   Inside containers, generate-secrets.sh maps to NON-PREFIXED names
#   (JWT_SECRET, DATABASE_URL) that each service's code expects.
#
# SECURITY:
#   - NEVER commit .env to git (gitignored)
#   - DB passwords: alphanumeric only (avoid Docker/Postgres escaping issues)
#   - Secrets: minimum 32 characters, generated with: openssl rand -hex 32
#   - Passwords: generated with: openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 32
# =============================================================================


# =============================================================================
# SHARED INFRASTRUCTURE
# =============================================================================

# PostgreSQL Superuser (shared-postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=GENERATE_ME_alphanumeric_32
POSTGRES_DB=postgres

# Database Host (shared-postgres in k8s, localhost for local dev)
SHARED_DB_HOST=shared-postgres
SHARED_DB_PORT=5432

# Shared SMTP Configuration (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Cross-Service Auth & Cookies
# In production: .korczewski.de  |  In local dev: localhost
COOKIE_DOMAIN=localhost
AUTH_SERVICE_URL=http://localhost:5500

# Timezone
TZ=Europe/Berlin


# =============================================================================
# AUTH SERVICE (port 5500)
# =============================================================================
AUTH_PORT=5500
AUTH_NODE_ENV=development
AUTH_DATABASE_URL=postgresql://auth_user:GENERATE_ME@shared-postgres:5432/auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=GENERATE_ME_alphanumeric_32

# JWT Secrets (minimum 32 chars — openssl rand -hex 32)
AUTH_JWT_SECRET=GENERATE_ME_hex_64
AUTH_JWT_REFRESH_SECRET=GENERATE_ME_hex_64
AUTH_ACCESS_TOKEN_EXPIRY=15m
AUTH_REFRESH_TOKEN_EXPIRY=7d

# Session
AUTH_SESSION_SECRET=GENERATE_ME_hex_64
AUTH_SESSION_MAX_AGE=2592000000

# Google OAuth
AUTH_GOOGLE_CLIENT_ID=your-google-client-id
AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_GOOGLE_REDIRECT_URI=http://localhost:5500/api/oauth/google/callback

# OAuth 2.0 Server (auth service as OAuth provider for other apps)
AUTH_OAUTH_CODE_EXPIRY=600
AUTH_OAUTH_ALLOWED_REDIRECT_URIS=https://l2p.korczewski.de/auth/callback,http://localhost:3000/auth/callback,https://shop.korczewski.de/auth/callback,http://localhost:3004/auth/callback,https://videovault.korczewski.de/auth/callback,http://localhost:5100/auth/callback

# Allowed Origins (CORS)
AUTH_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3004,http://localhost:4100,http://localhost:5000,http://localhost:5100,http://localhost:5500,https://auth.korczewski.de,https://l2p.korczewski.de,https://shop.korczewski.de,https://videovault.korczewski.de
AUTH_APP_URL=http://localhost:5500

# Security
AUTH_BCRYPT_ROUNDS=12
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_ACCOUNT_LOCKOUT_DURATION=900000


# =============================================================================
# SHOP SERVICE (port 3004, Next.js)
# =============================================================================
SHOP_DATABASE_URL="postgresql://shop_user:GENERATE_ME@shared-postgres:5432/shop_db?schema=public"
SHOP_DB_USER=shop_user
SHOP_DB_PASSWORD=GENERATE_ME_alphanumeric_32

# NextAuth
SHOP_NEXTAUTH_SECRET=GENERATE_ME_hex_64
SHOP_NEXTAUTH_URL=http://localhost:3004

# Google OAuth (NextAuth provider)
SHOP_AUTH_GOOGLE_ID=your-google-client-id
SHOP_AUTH_GOOGLE_SECRET=your-google-client-secret

# Stripe (use test keys for development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Client Auth
SHOP_AUTH_SECRET=GENERATE_ME_hex_64
SHOP_AUTH_TRUST_HOST=true


# =============================================================================
# L2P SERVICE (Learn2Play — backend port 3001, frontend port 3000)
# =============================================================================
L2P_NODE_ENV=development
L2P_PORT=3001
L2P_FRONTEND_PORT=3000
L2P_FRONTEND_URL=http://localhost:3000

# Database
L2P_DATABASE_URL=postgresql://l2p_user:GENERATE_ME@shared-postgres:5432/l2p_db
L2P_DB_NAME=l2p_db
L2P_DB_USER=l2p_user
L2P_DB_PASSWORD=GENERATE_ME_alphanumeric_32

# JWT (L2P-specific, separate from auth service)
L2P_JWT_SECRET=GENERATE_ME_hex_64
L2P_JWT_REFRESH_SECRET=GENERATE_ME_hex_64

# OAuth Client (L2P as client of Auth Service)
L2P_OAUTH_CLIENT_ID=l2p_client_prod
L2P_OAUTH_CLIENT_SECRET=GENERATE_ME_alphanumeric_32
L2P_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# CORS
L2P_CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5500,https://auth.korczewski.de,https://l2p.korczewski.de,https://shop.korczewski.de,https://videovault.korczewski.de

# Security
L2P_FORCE_HTTPS=false
L2P_TRUSTED_PROXIES=127.0.0.1


# =============================================================================
# VIDEOVAULT SERVICE (port 5100)
# =============================================================================
VIDEO_PORT=5100
VIDEO_NODE_ENV=development
VIDEO_DATABASE_URL=postgresql://videovault_user:GENERATE_ME@shared-postgres:5432/videovault_db
VIDEOVAULT_DB_USER=videovault_user
VIDEOVAULT_DB_PASSWORD=GENERATE_ME_alphanumeric_32

# Session & Admin
VIDEO_SESSION_SECRET=GENERATE_ME_hex_64
VIDEO_ADMIN_USER=admin
VIDEO_ADMIN_PASS=GENERATE_ME_alphanumeric_16

# Media Paths (adjust to your local setup)
VIDEO_MEDIA_ROOT=/path/to/your/media
# VIDEO_PROCESSED_MEDIA_PATH=/path/to/processed/videos

# CORS & Proxy
VIDEO_CORS_ORIGINS=http://localhost:5100,http://localhost:5000,https://videovault.korczewski.de
VIDEO_TRUST_PROXY=false


# =============================================================================
# ARENA SERVICE (backend port 3003, frontend port 3002)
# =============================================================================
ARENA_DB_USER=arena_user
ARENA_DB_PASSWORD=GENERATE_ME_alphanumeric_32

# ElevenLabs API (for cloud SFX generation)
# Only used when --backend elevenlabs or auto mode with no local AudioCraft GPU
ELEVENLABS_API_KEY=your-elevenlabs-api-key


# =============================================================================
# ASSETGENERATOR SERVICE (port 5200)
# =============================================================================
# API keys for AI-powered asset generation (all optional)
GEMINI_API_KEY=your-gemini-api-key
SILICONFLOW_API_KEY=your-siliconflow-api-key
SUNO_API_KEY=your-suno-api-key


# =============================================================================
# REVERSE PROXY (TRAEFIK)
# =============================================================================
TRAEFIK_ACME_EMAIL=your-email@example.com
TRAEFIK_DASHBOARD_USER=admin
# Generate with: htpasswd -nb admin yourpassword
TRAEFIK_DASHBOARD_PASSWORD_HASH=$apr1$placeholder$placeholder

# Docker Registry (basic auth for registry.korczewski.de)
# Generate password hash with: htpasswd -Bn registry
REGISTRY_USER=registry
REGISTRY_PASSWORD=GENERATE_ME_alphanumeric_32
REGISTRY_PASSWORD_HASH=$2y$05$placeholder

# IPv64 Dynamic DNS
IPV64_API_KEY=your-ipv64-api-key


# =============================================================================
# SMB STORAGE (shared NAS)
# =============================================================================
SMB_USER=your-smb-user
SMB_PASSWORD=your-smb-password
SMB_SERVER=10.10.0.3
SMB_SHARE=SMB-Share


# =============================================================================
# TESTING
# =============================================================================
# Shared key for bypassing rate limiting during automated browser tests.
# Requests with header X-Rate-Limit-Bypass matching this key skip all rate limiters.
# Generate with: openssl rand -hex 32
RATE_LIMIT_BYPASS_KEY=


# =============================================================================
# VLLM SERVICE (optional — local LLM inference)
# =============================================================================
# VLLM_PORT=4100
# VLLM_HF_TOKEN=hf_your_huggingface_token
# VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct-AWQ
# VLLM_IMAGE=vllm/vllm-openai:latest
# VLLM_PLATFORM=linux/amd64
# VLLM_BASE_URL=http://localhost:4100
# VLLM_API_KEY=GENERATE_ME_hex_64
# VLLM_DATABASE_URL=postgresql://webui:webui@localhost:5438/webui
# VLLM_ADMIN_PASSWORD=GENERATE_ME_alphanumeric_16
# VLLM_DASHBOARD_PORT=4242
# WEBUI_SECRET_KEY=GENERATE_ME_hex_64
# CORS_ALLOW_ORIGIN=http://localhost:3000;http://localhost:4100
