# =============================================================================
# VideoVault Service — LOCAL DEVELOPMENT Reference
# =============================================================================
# For k3s deployment, all secrets are defined in the ROOT .env:
#   /home/patrick/projects/.env  (VIDEO_* / VIDEOVAULT_* prefixed variables)
#
# generate-secrets.sh maps ROOT variables to K8s secret fields:
#   VIDEO_DATABASE_URL    →  VIDEO_DATABASE_URL
#   VIDEO_SESSION_SECRET  →  VIDEO_SESSION_SECRET
#   VIDEO_ADMIN_USER      →  VIDEO_ADMIN_USER
#   VIDEO_ADMIN_PASS      →  VIDEO_ADMIN_PASS
#
# To bootstrap from scratch:
#   cd /home/patrick/projects
#   ./scripts/generate-env.sh
#   ./k8s/scripts/utils/generate-secrets.sh
# =============================================================================

# Server
NODE_ENV=development
PORT=5100

# Database (optional — enables server-side persistence)
# Local dev: localhost:5432, k8s: shared-postgres:5432
DATABASE_URL=postgresql://videovault_user:videovault_password@localhost:5432/videovault_db

# Session (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# Admin Authentication
ADMIN_USER=admin
ADMIN_PASS=your-admin-password

# Media Paths
MEDIA_ROOT=/path/to/your/media
# PROCESSED_MEDIA_PATH=/path/to/processed/videos
# MOVIES_DIR=/path/to/your/media/movies
# INBOX_DIR=/path/to/inbox

# Movie Watcher (optional)
# ENABLE_MOVIE_WATCHER=1
# MOVIE_WATCHER_INTERVAL_MS=15000
# MOVIE_WATCHER_STABILITY_MS=30000
# MOVIE_WATCHER_AUTO_ORGANIZE=1
# MOVIE_WATCHER_BACKFILL=0

# CORS & Proxy
CORS_ORIGINS=http://localhost:5100,http://localhost:5000
TRUST_PROXY=false
