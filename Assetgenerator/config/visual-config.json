{
  "libraryRoot": "/mnt/pve3a/visual-library",
  "blenderPath": "blender",
  "categories": {
    "characters": {
      "directions": 8,
      "defaultPoses": ["stand", "gun", "machine", "reload", "hold", "silencer"],
      "size": 64,
      "conceptResolution": 1024,
      "has3D": true,
      "hasRig": true,
      "hasAnimations": true,
      "animationClips": [
        "idle", "walk", "run", "shoot", "melee", "throw",
        "hit_react", "death", "victory", "defeat",
        "thinking", "celebrate", "wave", "clap", "thumbsup"
      ]
    },
    "weapons": {
      "directions": 1,
      "defaultPoses": ["idle"],
      "size": 32,
      "animated": true,
      "has3D": true
    },
    "items": {
      "directions": 1,
      "defaultPoses": ["idle"],
      "size": 32,
      "has3D": true
    },
    "tiles": {
      "directions": 1,
      "defaultPoses": ["idle"],
      "size": 32,
      "has3D": false,
      "conceptResolution": 512
    },
    "cover": {
      "directions": 1,
      "defaultPoses": ["idle"],
      "size": 32,
      "has3D": true
    },
    "ui": {
      "directions": 1,
      "defaultPoses": ["idle"],
      "size": 16,
      "has3D": false,
      "conceptResolution": 512
    }
  },
  "render": {
    "engine": "EEVEE",
    "resolution": 256,
    "format": "PNG"
  },
  "atlas": {
    "maxSize": 2048,
    "padding": 2,
    "powerOfTwo": true
  },
  "tags": ["arena", "fantasy", "sci-fi", "medieval", "modern", "nature"]
}
